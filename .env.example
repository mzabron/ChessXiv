# Docker Database Configuration
CHESSXIV_DB_HOST=localhost
CHESSXIV_DB_PORT=5432
CHESSXIV_DB_NAME=chessxiv_db
CHESSXIV_DB_USER=chessxiv_user
CHESSXIV_DB_PASSWORD=

# Used by CLI importer (optional)
CHESSXIV_CONNECTION_STRING=Host=localhost;Port=5432;Database=chessxiv_db;Username=chessxiv_user;Password=